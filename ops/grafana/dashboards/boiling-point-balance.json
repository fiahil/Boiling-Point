{
  "annotations": { "list": [] },
  "editable": false,
  "title": "Boiling Point — Balance (Principle IV)",
  "uid": "bp-balance",
  "tags": ["boiling-point", "balance"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Explosion rate (target 30–40%)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0.3 },
              { "color": "yellow", "value": 0.4 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(round_explosions_total[$__range])) / clamp_min(sum(increase(rounds_total[$__range])), 1)"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Explosion rate over time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(round_explosions_total[$__rate_interval])) / clamp_min(sum(rate(rounds_total[$__rate_interval])), 0.0001)",
          "legendFormat": "explosion rate"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Cards per round",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2 } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(cards_committed_total[$__range])) / clamp_min(sum(increase(rounds_total[$__range])), 1)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg round duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 1 } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(round_duration_seconds_sum[$__range])) / clamp_min(sum(increase(round_duration_seconds_count[$__range])), 1)"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Avg game duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 1 } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(game_duration_seconds_sum[$__range])) / clamp_min(sum(increase(game_duration_seconds_count[$__range])), 1)"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Active groups",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "groups_active"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Dominant-colour rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(round_dominations_total[$__range])) / clamp_min(sum(increase(round_dominations_total[$__range])) + sum(increase(round_splits_total[$__range])), 1)"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Wave timeout rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(wave_timeouts_total[$__range])) / clamp_min(sum(increase(waves_total[$__range])), 1)"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Reconnections per game",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2 } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(player_reconnects_total[$__range])) / clamp_min(sum(increase(games_completed_total[$__range])), 1)"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Reshuffle frequency (per second)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(deck_reshuffles_total[$__rate_interval]))",
          "legendFormat": "reshuffles/s"
        }
      ]
    }
  ]
}
