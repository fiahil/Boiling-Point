{
  "annotations": {
    "list": []
  },
  "editable": false,
  "title": "Boiling Point — Balance v2 (Principle IV)",
  "uid": "bp-balance",
  "tags": [
    "boiling-point",
    "balance",
    "boom2"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Boom rate — target ~45% [needs playtesting]",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "yellow",
                "value": null
              },
              {
                "color": "green",
                "value": 0.4
              },
              {
                "color": "yellow",
                "value": 0.5
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(rounds_boomed_total[$__range])) / clamp_min(sum(increase(rounds_total[$__range])), 1)"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Boom rate over time",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(rounds_boomed_total[$__rate_interval])) / clamp_min(sum(rate(rounds_total[$__rate_interval])), 0.0001)",
          "legendFormat": "boom rate"
        }
      ]
    },
    {
